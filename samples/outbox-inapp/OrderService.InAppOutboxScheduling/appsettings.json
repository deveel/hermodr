{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      // Show relay activity so you can see messages being picked up and forwarded.
      "Hermodr": "Debug"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    // SQLite outbox database — created automatically on first run.
    "Outbox": "Data Source=outbox-scheduling.db"
  },

  "Events": {
    "RabbitMq": {
      // AMQP connection URI — override via environment variable or user-secrets.
      "ConnectionString": "amqp://guest:guest@localhost:5672",

      // Default exchange — per-event [AmqpExchange] annotations override this.
      "ExchangeName": "orders",

      // Deliver each message durably and wait for broker acknowledgement.
      "PersistentMessages": true,
      "PublisherConfirms": true,
      "ConfirmTimeout": "00:00:05",

      // Friendly name shown in the RabbitMQ management UI.
      "ClientName": "order-service-outbox-scheduling"
    }
  }
}

