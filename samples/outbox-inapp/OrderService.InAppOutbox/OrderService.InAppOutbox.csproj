<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OrderService</RootNamespace>
    <AssemblyName>OrderService.InAppOutbox</AssemblyName>
    <Description>
      Sample ASP.NET Minimal API that demonstrates the Transactional Outbox pattern
      using Deveel.Events: order domain events are first persisted to a SQLite outbox
      (via EF Core) and then forwarded to RabbitMQ by a relay BackgroundService running
      inside the same application process.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.5" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.5" />
  </ItemGroup>

  <ItemGroup>
    <!-- Deveel.Events: outbox pattern (EF Core) + RabbitMQ transport channel -->
    <ProjectReference Include="..\..\..\src\Deveel.Events.Publisher.Outbox.EntityFramework\Deveel.Events.Publisher.Outbox.EntityFramework.csproj" />
    <ProjectReference Include="..\..\..\src\Deveel.Events.Publisher.RabbitMq\Deveel.Events.Publisher.RabbitMq.csproj" />
  </ItemGroup>

</Project>

