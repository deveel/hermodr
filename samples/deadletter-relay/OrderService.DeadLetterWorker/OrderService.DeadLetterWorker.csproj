<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OrderService.DeadLetterWorker</RootNamespace>
    <AssemblyName>OrderService.DeadLetterWorker</AssemblyName>
    <Description>
      Worker sample that demonstrates the second half of a split dead-letter flow:
      it polls a shared EF Core dead-letter store and replays pending CloudEvents through
      a recovery channel.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.5" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.0.5" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Deveel.Events.Publisher.DeadLetter.EntityFramework\Deveel.Events.Publisher.DeadLetter.EntityFramework.csproj" />
  </ItemGroup>

</Project>
