<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OrderService.InProcDeadLetter</RootNamespace>
    <AssemblyName>OrderService.InProcDeadLetter</AssemblyName>
    <Description>
      Console sample that demonstrates in-process dead-letter handling using Hermodr:
      a failing publish is intercepted, transformed into a dead-letter callback, and replayed
      immediately through the same publisher pipeline to a recovery channel.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="9.0.5" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Hermodr.Publisher\Hermodr.Publisher.csproj" />
    <ProjectReference Include="..\..\..\src\Hermodr.Publisher.DeadLetter\Hermodr.Publisher.DeadLetter.csproj" />
  </ItemGroup>

</Project>
