{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      // Show outbox write activity.
      "Hermodr": "Debug"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    // SQLite outbox database — created automatically on first run.
    // Both the API and the relay worker must point to the same file.
    "Outbox": "Data Source=outbox.db"
  }
}

