<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OrderService</RootNamespace>
    <AssemblyName>OrderService.Api</AssemblyName>
    <Description>
      Sample ASP.NET Minimal API that demonstrates the first half of the split Transactional Outbox
      pattern using Deveel.Events: order domain events are persisted to a SQLite outbox (via EF Core)
      and then left for the external OrderService.RelayWorker process to pick up and forward to
      RabbitMQ via MassTransit.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CloudNative.CloudEvents" Version="2.8.0" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="9.0.5" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="9.0.15" />
  </ItemGroup>

  <ItemGroup>
    <!-- Only the outbox persistence channel is needed here — no transport dependency. -->
    <Reference Include="Deveel.Events.Annotations">
      <HintPath>..\libs\Deveel.Events.Annotations.dll</HintPath>
    </Reference>
    <Reference Include="Deveel.Events.Publisher">
      <HintPath>..\libs\Deveel.Events.Publisher.dll</HintPath>
    </Reference>
    <Reference Include="Deveel.Events.Publisher.Outbox">
      <HintPath>..\libs\Deveel.Events.Publisher.Outbox.dll</HintPath>
    </Reference>
    <Reference Include="Deveel.Events.Publisher.Outbox.EntityFramework">
      <HintPath>..\libs\Deveel.Events.Publisher.Outbox.EntityFramework.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>

