{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      // Show relay poll cycles and per-message dispatch activity.
      "Hermodr": "Debug",
      "MassTransit": "Information"
    }
  },

  "ConnectionStrings": {
    // Must point to the same SQLite file that OrderService.Api writes to.
    // Adjust this path (or use an environment variable) when running both processes
    // from different working directories.
    // For production, replace SQLite with SQL Server or PostgreSQL.
    "Outbox": "Data Source=../OrderService.Api/outbox.db"
  },

  "Events": {
    "MassTransit": {
      "RabbitMq": {
        // Override via environment variables or user-secrets in production.
        "Host":     "localhost",
        "Username": "guest",
        "Password": "guest"
      }
    }
  }
}

